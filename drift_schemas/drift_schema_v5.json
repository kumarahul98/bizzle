  "fixed_sql": [
    {
      "name": "trips",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"trips\" (\"id\" TEXT NOT NULL, \"user_id\" TEXT NOT NULL DEFAULT 'local_user', \"start_time\" INTEGER NOT NULL, \"end_time\" INTEGER NOT NULL, \"duration_seconds\" INTEGER NOT NULL, \"total_paused_seconds\" INTEGER NOT NULL DEFAULT 0, \"distance_meters\" REAL NOT NULL, \"route_polyline\" TEXT NULL, \"direction\" TEXT NOT NULL, \"time_moving_seconds\" INTEGER NOT NULL, \"time_stuck_seconds\" INTEGER NOT NULL, \"is_manual_entry\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_manual_entry\" IN (0, 1)), \"is_edited\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_edited\" IN (0, 1)), \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"updated_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "sync_queue",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sync_queue\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"trip_id\" TEXT NOT NULL, \"action\" TEXT NOT NULL, \"payload\" TEXT NULL, \"status\" TEXT NOT NULL DEFAULT 'pending', \"retry_count\" INTEGER NOT NULL DEFAULT 0, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"synced_at\" INTEGER NULL);"
        }
      ]
    },
    {
      "name": "user_preferences",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"user_preferences\" (\"id\" INTEGER NOT NULL, \"user_id\" TEXT NOT NULL DEFAULT 'local_user', \"dark_mode\" TEXT NOT NULL DEFAULT 'system', \"morning_cutoff_hour\" INTEGER NOT NULL DEFAULT 12, \"evening_cutoff_hour\" INTEGER NOT NULL DEFAULT 12, \"reminder_enabled\" INTEGER NOT NULL DEFAULT 0 CHECK (\"reminder_enabled\" IN (0, 1)), \"reminder_time\" TEXT NULL, \"weekend_reminder\" INTEGER NOT NULL DEFAULT 0 CHECK (\"weekend_reminder\" IN (0, 1)), \"weekly_notification_enabled\" INTEGER NOT NULL DEFAULT 0 CHECK (\"weekly_notification_enabled\" IN (0, 1)), \"auto_pause_enabled\" INTEGER NOT NULL DEFAULT 0 CHECK (\"auto_pause_enabled\" IN (0, 1)), \"has_seen_onboarding\" INTEGER NOT NULL DEFAULT 0 CHECK (\"has_seen_onboarding\" IN (0, 1)), PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "trip_breaks",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"trip_breaks\" (\"id\" TEXT NOT NULL, \"trip_id\" TEXT NOT NULL REFERENCES trips (id), \"start_time\" INTEGER NOT NULL, \"end_time\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },

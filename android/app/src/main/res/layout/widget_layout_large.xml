<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 28 — LARGE (full-width, ~4x2) widget variant.

  Android picks between this and the compact widget_layout.xml automatically via
  the RemoteViews(Map<SizeF, RemoteViews>) constructor in CommuteWidgetProvider
  (API 31+; minSdk here is 34). Button IDs are IDENTICAL to the compact layout so
  the existing click intents work unchanged in both variants.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:gravity="center_vertical"
    android:padding="10dp">

    <!-- IDLE STATE: START button + today/this-week stats -->
    <LinearLayout
        android:id="@+id/widget_idle_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:id="@+id/btn_start_commute"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/widget_btn_record"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_media_play"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="START"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="1dp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:textColor="#9A9AAA"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="1dp">
                <TextView
                    android:id="@+id/widget_today_trips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#F2F2F5"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_today_traffic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="#8AABCF"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THIS WEEK"
                android:textColor="#9A9AAA"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="1dp">
                <TextView
                    android:id="@+id/widget_week_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#F2F2F5"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_week_stuck"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="#E8A33D"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ACTIVE STATE: live stats block + PAUSE/STOP -->
    <LinearLayout
        android:id="@+id/widget_active_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Row 1: DIST / TIME / SPEED -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DIST"
                        android:textColor="#9A9AAA"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/widget_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#5EED9E"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TIME"
                        android:textColor="#9A9AAA"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/widget_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#8AABCF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPEED"
                        android:textColor="#9A9AAA"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/widget_speed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#F2F2F5"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: moving vs stuck + PAUSED chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MOVING"
                    android:textColor="#9A9AAA"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
                <TextView
                    android:id="@+id/widget_moving"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#5EED9E"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STUCK"
                    android:textColor="#9A9AAA"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginStart="10dp" />
                <TextView
                    android:id="@+id/widget_stuck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#E8A33D"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/widget_paused"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAUSED"
                    android:textColor="#1A1C1E"
                    android:background="#E8A33D"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginStart="10dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- PAUSE + STOP -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="10dp">

            <LinearLayout
                android:id="@+id/btn_pause_commute"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_btn_pause"
                android:layout_marginEnd="8dp"
                android:elevation="2dp">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_pause"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_stop_commute"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_btn_record"
                android:elevation="2dp">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_ff"
                    android:tint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact 2x2 commute widget. Both states are sized to fit under the ~110dp
  interior of the default 2x2 cell so the circular buttons render fully instead
  of being clipped into half-circles (WIDGET-01 device-UAT fix). IDs are read by
  CommuteWidgetProvider.onUpdate — do not rename them.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:gravity="center"
    android:padding="8dp">

    <!-- IDLE STATE -->
    <LinearLayout
        android:id="@+id/widget_idle_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Circular crimson START button (tap target = whole circle) -->
        <FrameLayout
            android:id="@+id/btn_start_commute"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/widget_btn_record"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_media_play"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="START"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="1dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- ACTIVE STATE -->
    <LinearLayout
        android:id="@+id/widget_active_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <!-- STATS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIST"
                    android:textColor="#9A9AAA"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
                <TextView
                    android:id="@+id/widget_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#5EED9E"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIME"
                    android:textColor="#9A9AAA"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
                <TextView
                    android:id="@+id/widget_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#8AABCF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- PAUSE + STOP buttons row (icon-only to stay within 2x2) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/btn_pause_commute"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_btn_pause"
                android:layout_marginEnd="12dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_pause"
                    android:tint="#FFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_stop_commute"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_btn_record"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_ff"
                    android:tint="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>

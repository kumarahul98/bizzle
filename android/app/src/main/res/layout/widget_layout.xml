<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp"
    android:gravity="center"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- IDLE STATE: mirrors app hero section -->
    <LinearLayout
        android:id="@+id/widget_idle_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Commute-ready label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAP TO START COMMUTE"
            android:textColor="#9A9AAA"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:layout_marginBottom="12dp" />

        <!-- Circular crimson START button (matches hero_record_card _HeroIdle) -->
        <FrameLayout
            android:id="@+id/btn_start_commute"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/widget_btn_record"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_media_play"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="START"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- ACTIVE STATE -->
    <LinearLayout
        android:id="@+id/widget_active_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <!-- STATS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIST"
                    android:textColor="#9A9AAA"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
                <TextView
                    android:id="@+id/widget_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#5EED9E"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIME"
                    android:textColor="#9A9AAA"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
                <TextView
                    android:id="@+id/widget_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#8AABCF"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- PAUSE + STOP buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Pause: orange-ish circle -->
            <LinearLayout
                android:id="@+id/btn_pause_commute"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_btn_pause"
                android:layout_marginEnd="16dp"
                android:elevation="6dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_media_pause"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAUSE"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Stop: crimson circle (same as record) -->
            <LinearLayout
                android:id="@+id/btn_stop_commute"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_btn_record"
                android:elevation="6dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_media_ff"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STOP"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>

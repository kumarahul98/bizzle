{
  "name": "functions",
  "description": "Commute Tracker backend — Cloud Functions (trips sync/delete/restore)",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth",
    "test": "firebase --project travey-298a7 --config ../firebase.json emulators:exec --only auth,firestore \"jest --runInBand\"",
    "test:watch": "firebase --project travey-298a7 --config ../firebase.json emulators:exec --only auth,firestore \"jest --watch --runInBand\"",
    "test:unit": "jest --selectProjects unit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5"
  }
}
